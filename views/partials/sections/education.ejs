<section id="education" class="section-py">
  <div class="container">
    <div class="section-header text-center mb-5" data-aos="fade-up">
      <span class="section-label">Học vấn</span>
      <h2 class="section-heading">Education</h2>
    </div>
    <div class="row justify-content-center">
      <div class="col-lg-8" data-aos="zoom-in">
        <div class="education-card p-4 p-md-5 rounded-4 text-center">
          <div class="education-icon mb-3">
            <i class="fas fa-graduation-cap"></i>
          </div>
          <h3 class="h4 fw-bold mb-2"><%= site.education.school %></h3>
          <p class="fs-5 mb-1"><%= site.education.major %></p>
          <p class="mb-2">
            <span class="badge gpa-badge">GPA: <%= site.education.gpa %>/4.0</span>
          </p>
          <p class="text-muted mb-0"><i class="far fa-calendar me-2"></i><%= site.education.period %></p>
        </div>
      </div>
    </div>
  </div>
</section>
