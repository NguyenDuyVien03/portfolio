<section id="contact" class="section contact-section">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label"><%= t('contact.label') %></span>
      <h2 class="section-title"><%- t('contact.title') %></h2>
      <p class="section-subtitle"><%= t('contact.subtitle') %></p>
    </div>

    <div class="contact-grid">
      <div class="contact-info reveal-left">
        <h3><%= t('contact.infoTitle') %></h3>
        <p><%= t('contact.infoDesc') %></p>

        <div class="contact-links">
          <a href="mailto:<%= site.profile.email %>" class="contact-link-item">
            <div class="contact-link-icon"><i class="fa-solid fa-envelope"></i></div>
            <div>
              <div class="contact-link-label"><%= t('contact.email') %></div>
              <div class="contact-link-value"><%= site.profile.email %></div>
            </div>
          </a>
          <a href="<%= site.profile.github %>" target="_blank" rel="noopener" class="contact-link-item">
            <div class="contact-link-icon"><i class="fab fa-github"></i></div>
            <div>
              <div class="contact-link-label"><%= t('contact.github') %></div>
              <div class="contact-link-value">@<%= site.profile.github.split('/').pop() %></div>
            </div>
          </a>
          <a href="<%= site.profile.linkedin %>" target="_blank" rel="noopener" class="contact-link-item">
            <div class="contact-link-icon"><i class="fab fa-linkedin-in"></i></div>
            <div>
              <div class="contact-link-label"><%= t('contact.linkedin') %></div>
              <div class="contact-link-value"><%= site.profile.linkedin.split('/').pop() %></div>
            </div>
          </a>
          <a href="<%= site.profile.facebook %>" target="_blank" rel="noopener" class="contact-link-item">
            <div class="contact-link-icon"><i class="fab fa-facebook-f"></i></div>
            <div>
              <div class="contact-link-label"><%= t('contact.facebook') %></div>
              <div class="contact-link-value"><%= site.profile.facebook.split('/').pop() %></div>
            </div>
          </a>
          <a href="<%= site.profile.cvUrl %>" class="contact-link-item" download>
            <div class="contact-link-icon"><i class="fa-solid fa-file-arrow-down"></i></div>
            <div>
              <div class="contact-link-label"><%= t('contact.downloadCV') %></div>
              <div class="contact-link-value"><%= t('contact.pdfFormat') %></div>
            </div>
          </a>
        </div>
      </div>

      <div class="contact-form reveal-right">
        <form id="contactForm" novalidate>
          <div id="contactAlert" class="form-alert"></div>
          <div class="form-row">
            <div class="form-group">
              <label for="name" class="form-label"><%= t('contact.formName') %></label>
              <input type="text" class="form-input" id="name" name="name" required placeholder="<%= t('contact.namePlaceholder') %>" />
            </div>
            <div class="form-group">
              <label for="email" class="form-label"><%= t('contact.formEmail') %></label>
              <input type="email" class="form-input" id="email" name="email" required placeholder="<%= t('contact.emailPlaceholder') %>" />
            </div>
          </div>
          <div class="form-group">
            <label for="subject" class="form-label"><%= t('contact.formSubject') %></label>
            <input type="text" class="form-input" id="subject" name="subject" placeholder="<%= t('contact.subjectPlaceholder') %>" />
          </div>
          <div class="form-group">
            <label for="message" class="form-label"><%= t('contact.formMessage') %></label>
            <textarea class="form-textarea" id="message" name="message" required placeholder="<%= t('contact.messagePlaceholder') %>"></textarea>
          </div>
          <button type="submit" class="btn btn-primary" id="contactSubmit" style="width:100%;justify-content:center">
            <i class="fa-solid fa-paper-plane"></i> <%= t('contact.send') %>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
