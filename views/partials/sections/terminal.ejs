<section id="terminal" class="section terminal-section">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label"><%= t('terminal.label') %></span>
      <h2 class="section-title"><%- t('terminal.title') %></h2>
      <p class="section-subtitle"><%- t('terminal.subtitle') %></p>
    </div>

    <div class="terminal reveal">
      <div class="terminal-header">
        <span class="terminal-dot red"></span>
        <span class="terminal-dot yellow"></span>
        <span class="terminal-dot green"></span>
        <span class="terminal-title">portfolio@terminal — bash</span>
      </div>
      <div class="terminal-body" id="terminalBody">
        <div class="terminal-output">
          <div class="terminal-output-line cyan"><%= t('terminal.welcome1') %></div>
          <div class="terminal-output-line cyan"><%= t('terminal.welcome2') %></div>
          <div class="terminal-output-line cyan"><%= t('terminal.welcome3') %></div>
          <div class="terminal-output-line dim"> </div>
          <div class="terminal-output-line dim"><%- t('terminal.hint') %></div>
          <div class="terminal-output-line dim"> </div>
        </div>
        <div class="terminal-output" id="terminalOutput"></div>
        <div class="terminal-input-line">
          <span class="terminal-prompt">visitor@portfolio:~$</span>
          <input type="text" class="terminal-input" id="terminalInput" autofocus spellcheck="false" autocomplete="off" />
        </div>
      </div>
    </div>
  </div>
</section>

<script>
window.__terminalResponses = {
  lang: '<%= lang %>',
  about: <%- JSON.stringify(lang === 'en' && site.terminalResponses.aboutEn ? site.terminalResponses.aboutEn : site.terminalResponses.about) %>,
  skills: <%- JSON.stringify(site.terminalResponses.skills) %>,
  projects: <%- JSON.stringify(lang === 'en' && site.terminalResponses.projectsEn ? site.terminalResponses.projectsEn : site.terminalResponses.projects) %>,
  contact: <%- JSON.stringify(lang === 'en' && site.terminalResponses.contactEn ? site.terminalResponses.contactEn : site.terminalResponses.contact) %>,
  education: <%- JSON.stringify(lang === 'en' && site.terminalResponses.educationEn ? site.terminalResponses.educationEn : site.terminalResponses.education) %>,
};
window.__terminalCommands = <%- JSON.stringify(site.terminalCommands.map(function(c) {
  return { cmd: c.cmd, description: lang === 'en' && c.descriptionEn ? c.descriptionEn : c.description };
})) %>;
</script>