<section id="about" class="section about-section">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label"><%= t('about.label') %></span>
      <h2 class="section-title"><%- t('about.title') %></h2>
      <p class="section-subtitle"><%= t('about.subtitle') %></p>
    </div>

    <div class="about-grid">
      <div class="about-story reveal-left">
        <% var storyData = lang === 'en' && site.about.storyEn ? site.about.storyEn : site.about.story; %>
        <% storyData.forEach(function(p) { %>
          <p><%= p %></p>
        <% }); %>
      </div>

      <div class="about-highlights reveal-right">
        <div class="about-highlights-grid">
          <% site.about.highlights.forEach(function(h) { %>
            <div class="about-highlight-card">
              <div class="about-highlight-icon"><i class="fas <%= h.icon %>"></i></div>
              <div class="about-highlight-label"><%= lang === 'en' && h.labelEn ? h.labelEn : h.label %></div>
              <div class="about-highlight-value"><%= lang === 'en' && h.valueEn ? h.valueEn : h.value %></div>
            </div>
          <% }); %>
        </div>
      </div>
    </div>
  </div>
</section>
