<!DOCTYPE html>
<html lang="vi" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="<%= site.profile.name %> - <%= site.profile.title %>. Portfolio cá nhân hiện đại, chuyên về Laravel, REST API, MySQL và Backend Architecture." />
  <meta name="keywords" content="backend developer, laravel, php, nodejs, REST API, portfolio, nguyenduyvien" />
  <meta name="author" content="<%= site.profile.name %>" />
  <meta property="og:title" content="<%= site.profile.name %> - Backend Developer Portfolio" />
  <meta property="og:description" content="Portfolio cá nhân - Backend Developer chuyên về Laravel, RESTful API và Backend Architecture." />
  <meta property="og:type" content="website" />
  <meta name="theme-color" content="#050505" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title><%= typeof title !== 'undefined' ? title + ' | ' : '' %><%= site.profile.name %> - Backend Developer</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <div class="cursor-glow" id="cursorGlow"></div>

  <nav class="navbar" id="mainNav">
    <div class="container">
      <a class="navbar-brand" href="/">
        <span class="brand-bracket">&lt;</span><span class="brand-name"><%= site.profile.name.split(' ').pop() %></span><span class="brand-bracket">/&gt;</span>
      </a>
      <div class="nav-links">
        <a href="/#hero" class="nav-link active">Home</a>
        <a href="/#about" class="nav-link">About</a>
        <a href="/#skills" class="nav-link">Skills</a>
        <a href="/#projects" class="nav-link">Projects</a>
        <a href="/#experience" class="nav-link">Journey</a>
        <a href="/#contact" class="nav-link">Contact</a>
        <button type="button" class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
          <i class="fas fa-moon" id="themeIcon"></i>
        </button>
      </div>
      <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <nav class="mobile-nav" id="mobileNav">
    <a href="/#hero" class="mobile-nav-link">Home</a>
    <a href="/#about" class="mobile-nav-link">About</a>
    <a href="/#skills" class="mobile-nav-link">Skills</a>
    <a href="/#projects" class="mobile-nav-link">Projects</a>
    <a href="/#experience" class="mobile-nav-link">Journey</a>
    <a href="/#contact" class="mobile-nav-link">Contact</a>
  </nav>

  <main>
    <%- body %>
  </main>

  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <p>&copy; <%= new Date().getFullYear() %> <%= site.profile.name %>. Built with Node.js, Express & EJS</p>
        <div class="footer-links">
          <a href="<%= site.profile.github %>" target="_blank" rel="noopener" aria-label="GitHub"><i class="fab fa-github"></i></a>
          <a href="<%= site.profile.linkedin %>" target="_blank" rel="noopener" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
          <a href="mailto:<%= site.profile.email %>" aria-label="Email"><i class="fas fa-envelope"></i></a>
        </div>
      </div>
    </div>
  </footer>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/axios@1.7.9/dist/axios.min.js"></script>
  <script src="/js/theme.js"></script>
  <script src="/js/main.js"></script>
</body>
</html>