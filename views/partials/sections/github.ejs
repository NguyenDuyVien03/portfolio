<section id="github" class="section github-section">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label"><%= t('github.label') %></span>
      <h2 class="section-title"><%- t('github.title') %></h2>
      <p class="section-subtitle"><%= t('github.subtitle') %></p>
    </div>

    <div id="githubSection" data-username="<%= github.username || '' %>">
      <% if (github.error) { %>
        <div class="form-alert error" style="display:block;text-align:center">
          <i class="fa-solid fa-triangle-exclamation me-2"></i><%= github.error %>
        </div>
      <% } else { %>
        <div class="github-stats-grid reveal">
          <div class="github-stat-card">
            <div class="github-stat-icon"><i class="fab fa-github"></i></div>
            <div class="github-stat-number" id="repoCount"><%= github.repoCount %></div>
            <div class="github-stat-label"><%= t('github.repos') %></div>
          </div>
          <div class="github-stat-card">
            <div class="github-stat-icon"><i class="fa-solid fa-code"></i></div>
            <div class="github-stat-number" id="topLanguage"><%= github.topLanguage %></div>
            <div class="github-stat-label"><%= t('github.language') %></div>
          </div>
          <div class="github-stat-card">
            <div class="github-stat-icon"><i class="fa-solid fa-star"></i></div>
            <div class="github-stat-number" id="commitCount">-</div>
            <div class="github-stat-label"><%= t('github.contributions') %></div>
          </div>
        </div>

        <h3 class="section-subtitle" style="text-align:center;margin-bottom:24px"><%= t('github.latest') %></h3>
        <div class="github-repos-grid" id="githubRepos">
          <% if (github.repos.length === 0) { %>
            <p class="text-muted" style="grid-column:1/-1;text-align:center"><%= t('github.loading') %></p>
          <% } %>
          <% github.repos.forEach(function(repo) { %>
            <div class="github-repo-card">
              <div class="github-repo-name">
                <a href="<%= repo.url %>" target="_blank" rel="noopener">
                  <i class="fab fa-github me-1"></i><%= repo.name %>
                </a>
              </div>
              <div class="github-repo-desc"><%= repo.description || t('github.noDesc') %></div>
              <div class="github-repo-meta">
                <span class="github-repo-lang">
                  <% if (repo.language) { %>
                    <span class="github-repo-lang-dot"></span><%= repo.language %>
                  <% } %>
                </span>
                <span><i class="fa-regular fa-star"></i> <%= repo.stars %></span>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>
  </div>
</section>