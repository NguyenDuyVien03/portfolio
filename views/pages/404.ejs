<section style="padding:120px 0;min-height:60vh;display:flex;align-items:center">
  <div class="container" style="text-align:center">
    <h1 style="font-size:5rem;font-weight:800;color:var(--accent);margin-bottom:8px">404</h1>
    <p style="color:var(--text-secondary);font-size:1.1rem"><%= typeof message !== 'undefined' ? message : t('error.404desc') %></p>
    <a href="/" class="btn btn-primary" style="display:inline-flex;width:auto;margin-top:24px"><%= t('error.backHome') %></a>
  </div>
</section>
