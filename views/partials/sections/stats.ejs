<section class="stats-section" id="stats">
  <div class="container">
    <div class="stats-grid">
      <div class="stat-item reveal">
        <div class="stat-icon"><i class="fa-solid fa-folder-open"></i></div>
        <div class="stat-number"><span class="stat-count" data-target="<%= site.stats.projects %>">0</span><span class="stat-plus">+</span></div>
        <div class="stat-label"><%= t('stats.projects') %></div>
      </div>
      <div class="stat-item reveal" style="transition-delay:0.1s">
        <div class="stat-icon"><i class="fa-solid fa-cubes"></i></div>
        <div class="stat-number"><span class="stat-count" data-target="<%= site.stats.technologies %>">0</span><span class="stat-plus">+</span></div>
        <div class="stat-label"><%= t('stats.technologies') %></div>
      </div>
      <div class="stat-item reveal" style="transition-delay:0.2s">
        <div class="stat-icon"><i class="fa-solid fa-code"></i></div>
        <div class="stat-number"><span class="stat-count" data-target="<%= site.stats.apis %>">0</span><span class="stat-plus">+</span></div>
        <div class="stat-label"><%= t('stats.apis') %></div>
      </div>
      <div class="stat-item reveal" style="transition-delay:0.3s">
        <div class="stat-icon"><i class="fa-solid fa-calendar"></i></div>
        <div class="stat-number"><span class="stat-count" data-target="<%= site.stats.yearsExperience %>">0</span><span class="stat-plus">+</span></div>
        <div class="stat-label"><%= t('stats.years') %></div>
      </div>
    </div>
  </div>
</section>
